{
  "name": "goddess-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply goddess-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply goddess-db --remote",
    "db:seed:local": "wrangler d1 execute goddess-db --local --file=migrations/seed.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250418.0",
    "wrangler": "^4.10.0",
    "typescript": "^5.7.0"
  }
}
